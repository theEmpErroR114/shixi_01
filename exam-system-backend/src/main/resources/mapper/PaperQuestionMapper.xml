<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.examsystem.mapper.PaperQuestionMapper">

    <resultMap id="BaseResultMap" type="com.examsystem.entity.PaperQuestion">
        <id column="id" property="id"/>
        <result column="paper_id" property="paperId"/>
        <result column="question_id" property="questionId"/>
        <result column="score" property="score"/>
        <result column="sort_order" property="sortOrder"/>
    </resultMap>

    <resultMap id="WithQuestionMap" type="com.examsystem.entity.PaperQuestion" extends="BaseResultMap">
        <association property="question" javaType="com.examsystem.entity.Question">
            <id column="q_id" property="questionId"/>
            <result column="q_course_id" property="courseId"/>
            <result column="q_question_type" property="questionType"/>
            <result column="q_content" property="content"/>
            <result column="q_answer" property="answer"/>
            <result column="q_analysis" property="analysis"/>
            <result column="q_difficulty" property="difficulty"/>
            <result column="q_teacher_id" property="teacherId"/>
            <result column="q_create_time" property="createTime"/>
        </association>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_paper_question (paper_id, question_id, score, sort_order)
        VALUES (#{paperId}, #{questionId}, #{score}, #{sortOrder})
    </insert>

    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_paper_question (paper_id, question_id, score, sort_order) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.paperId}, #{item.questionId}, #{item.score}, #{item.sortOrder})
        </foreach>
    </insert>

    <delete id="deleteByPaperId">
        DELETE FROM t_paper_question WHERE paper_id = #{paperId}
    </delete>

    <select id="selectByPaperId" resultMap="WithQuestionMap">
        SELECT
            pq.id, pq.paper_id, pq.question_id, pq.score, pq.sort_order,
            q.question_id AS q_id, q.course_id AS q_course_id, q.question_type AS q_question_type,
            q.content AS q_content, q.answer AS q_answer, q.analysis AS q_analysis,
            q.difficulty AS q_difficulty, q.teacher_id AS q_teacher_id, q.create_time AS q_create_time
        FROM t_paper_question pq
        LEFT JOIN t_question q ON pq.question_id = q.question_id
        WHERE pq.paper_id = #{paperId}
        ORDER BY pq.sort_order
    </select>

</mapper>
