<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.examsystem.mapper.AdminMapper">

    <resultMap id="BaseResultMap" type="com.examsystem.entity.Admin">
        <id column="admin_id" property="adminId"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="phone" property="phone"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM t_admin WHERE username = #{username}
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM t_admin WHERE admin_id = #{adminId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="adminId">
        INSERT INTO t_admin (username, password, real_name, phone, create_time)
        VALUES (#{username}, #{password}, #{realName}, #{phone}, #{createTime})
    </insert>

    <update id="update">
        UPDATE t_admin
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="phone != null">phone = #{phone},</if>
        </set>
        WHERE admin_id = #{adminId}
    </update>

    <update id="updatePassword">
        UPDATE t_admin SET password = #{password} WHERE admin_id = #{adminId}
    </update>

</mapper>
