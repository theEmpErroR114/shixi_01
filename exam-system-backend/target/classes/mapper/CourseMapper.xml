<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.examsystem.mapper.CourseMapper">

    <resultMap id="BaseResultMap" type="com.examsystem.entity.Course">
        <id column="course_id" property="courseId"/>
        <result column="course_name" property="courseName"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM t_course ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM t_course WHERE course_id = #{courseId}
    </select>

    <select id="findByKeyword" resultMap="BaseResultMap">
        SELECT * FROM t_course
        <where>
            <if test="keyword != null and keyword != ''">
                AND course_name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="countByKeyword" resultType="java.lang.Long">
        SELECT COUNT(*) FROM t_course
        <where>
            <if test="keyword != null and keyword != ''">
                AND course_name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="courseId">
        INSERT INTO t_course (course_name, description, create_time)
        VALUES (#{courseName}, #{description}, #{createTime})
    </insert>

    <update id="update">
        UPDATE t_course
        <set>
            <if test="courseName != null">course_name = #{courseName},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE course_id = #{courseId}
    </update>

    <delete id="deleteById">
        DELETE FROM t_course WHERE course_id = #{courseId}
    </delete>

</mapper>
